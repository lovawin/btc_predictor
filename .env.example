# Telegram
TELEGRAM_BOT_TOKEN=

# Trading mode: true = attempt live execution, false = paper only
LIVE_TRADING=false

# Defaults
DEFAULT_MAX_BET_USD=25
MIN_CONFIDENCE=0.58
HEDGE_CONFIDENCE_FLIP=0.62
MAX_DRAWDOWN_PCT=0.02
MIN_EXPECTED_EDGE_PCT=0.0015
COST_BUFFER_PCT=0.0008

# Market data
BINANCE_SYMBOL=BTCUSDT
COINGECKO_COIN_ID=bitcoin
CHAINLINK_RPC_URL=
# BTC/USD on Ethereum mainnet
CHAINLINK_BTC_USD_FEED=0xF4030086522a5bEEa4988F8ca5B36dbC97BeE88c

# Polymarket (fill for live)
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137
POLYMARKET_DEFAULT_MARKET_ID=
POLYMARKET_5M_SLUG_TEMPLATE=btc-updown-5m-{ts}
POLYMARKET_ROLL_TO_NEXT_SECONDS=90
AUTO_LOOP_INTERVAL_SEC=20
USER_KEY_STORE_PATH=.data/user_keys.json

# Optional per-user MX routing target for /setvpn mx
VPN_MX_PROXY_URL=
# Backward-compat alias (if set, used when VPN_MX_PROXY_URL is empty)
VPN_AU_PROXY_URL=
VPN_DEFAULT_REGION=mx

# Optional host WireGuard profile for /vpnon and /vpnoff (global VPN toggle)
VPN_WG_CONF=
